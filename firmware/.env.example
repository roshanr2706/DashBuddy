# Copy to `.env` and fill in. The real `.env` is gitignored — keep it that way.
# Injected at build time as CFG_* compiler defines (see scripts/load_env.py),
# then read by src/config.h. No quotes needed; values may contain spaces.

# Your 2.4 GHz WiFi. Leave WIFI_SSID blank to run fully offline (drives still
# log to flash and upload later once this is set).
WIFI_SSID=
WIFI_PASSWORD=

# Backend upload endpoint — the LAN IP of the machine running ../backend.
UPLOAD_URL=http://192.168.1.100:3000/api/drives

# Shared secret; MUST match the backend's DEVICE_KEY.
DEVICE_KEY=change-me

# ArduinoOTA password for wireless firmware updates.
OTA_PASSWORD=dashbuddy-ota
