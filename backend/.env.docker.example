# Optional overrides for `docker compose`. Copy to `.env` to use:
#     cp .env.docker.example .env
# docker compose reads this file automatically for ${VAR} substitution.

# Shared secret — MUST equal net::DEVICE_KEY in firmware/src/config.h.
DEVICE_KEY=change-me

# Host port the dashboard + upload endpoint are exposed on.
# (The container always listens on 3000 internally.)
HOST_PORT=3000
